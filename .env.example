# ============================================
# KOMMO CRM - Credenciais OAuth2
# ============================================
# Subdomínio da conta Kommo (ex: suaempresa)
# URL completa será: https://suaempresa.kommo.com
KOMMO_SUBDOMAIN=leandroleandroantunesadvcombr

# Client ID da integração (obtido ao criar integração no Kommo)
KOMMO_CLIENT_ID=

# Client Secret da integração
KOMMO_CLIENT_SECRET=

# Código de autorização (usado apenas uma vez para obter o primeiro token)
KOMMO_AUTHORIZATION_CODE=

# Redirect URI configurado na integração (deve coincidir exatamente)
KOMMO_REDIRECT_URI=https://seudominio.com/api/auth/kommo/callback

# Access Token (preenchido automaticamente após primeira autenticação)
KOMMO_ACCESS_TOKEN=

# Refresh Token (preenchido automaticamente após primeira autenticação)
KOMMO_REFRESH_TOKEN=

# ============================================
# BANCO DE DADOS - PostgreSQL (Neon - gratuito)
# ============================================
# Crie uma conta grátis em https://neon.tech
# Copie a connection string do dashboard do Neon
# Formato: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# URL para conexão direta (Prisma migrations) - também do dashboard Neon
# É a mesma URL mas com ?sslmode=require no final
DIRECT_URL=

# ============================================
# APLICAÇÃO
# ============================================
# Porta do servidor
PORT=3000

# URL base da aplicação
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ambiente (development | production)
NODE_ENV=development

# Secret para sessões e JWT do painel admin
APP_SECRET=

# ============================================
# SINCRONIZAÇÃO
# ============================================
# Intervalo de sincronização em minutos (padrão: 60)
SYNC_INTERVAL_MINUTES=60

# Timezone (padrão: America/Sao_Paulo)
TZ=America/Sao_Paulo

# ============================================
# REDIS (Cache e filas - opcional para MVP)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# ADMIN - Credenciais do painel administrativo
# ============================================
ADMIN_EMAIL=admin@suaempresa.com
ADMIN_PASSWORD=

# ============================================
# LOGS
# ============================================
LOG_LEVEL=info
